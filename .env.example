# ============================================================================
#  LUNAO ENVIRONMENT CONFIG
#  Copy this file to ".env.local" and paste your real keys.
#  Leave any block blank to keep that integration in safe DRY-RUN mode.
#  The full pipeline (CSV -> site -> deploy -> SMS) works WITHOUT any keys:
#  sites are served locally and SMS are simulated, so you can test instantly.
# ============================================================================

# ---- Local API server ------------------------------------------------------
PORT="8787"

# Public base used to build the clickable link inside each SMS.
# Leave blank to auto-use the Cloudflare project URL (live) or localhost (dry-run).
# Example (custom domain): SITE_BASE_URL="https://sites.yourdomain.com"
SITE_BASE_URL=""

# ---- Telnyx SMS (paste these to send REAL texts) ---------------------------
# Master switch. Keep "false" to keep SMS as "Coming Soon" (deploy still works).
# Set to "true" once Telnyx is funded to start sending real texts.
SMS_ENABLED="false"
# Get from https://portal.telnyx.com  (API Keys + a purchased SMS number)
TELNYX_API_KEY=""
# Sender number in E.164 format, e.g. +15125550182
TELNYX_PHONE_NUMBER=""
# Optional: Messaging Profile ID (recommended for deliverability)
TELNYX_MESSAGING_PROFILE_ID=""

# ---- Cloudflare Pages (paste these to deploy REAL live sites) --------------
# API token needs the "Cloudflare Pages: Edit" permission.
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ACCOUNT_ID=""
# The Pages project name (create it once in the Cloudflare dashboard).
CLOUDFLARE_PAGES_PROJECT="lunao-sites"
# Production branch of that Pages project (usually "main").
CLOUDFLARE_PAGES_BRANCH="main"

# ---- Google Maps (FUTURE — leave blank for CSV-only mode) ------------------
# When added, enables live lead discovery instead of CSV upload.
GOOGLE_MAPS_API_KEY=""

# ---- Anthropic Claude (powers the Site Editor AI code chat) ----------------
# Paste your key to enable the AI editor. Leave blank to hide/disable it.
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=""
# Optional model override (defaults to claude-sonnet-4-5).
ANTHROPIC_MODEL="claude-sonnet-4-5"

# ---- Gemini (powers the booking chatbot) -----------------------------------
# Paste your key to use Gemini 2.5 Flash Lite for the booking bot.
# Leave blank to use the built-in rule-based booking agent (still fully works).
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# Optional model override (defaults to gemini-2.5-flash-lite).
GEMINI_MODEL="gemini-2.5-flash-lite"
APP_URL=""

# ---- Public API base (used by the injected booking/chatbot widget) ---------
# Locally this is the dev API. Point it at your Railway deploy in production,
# then re-inject add-ons + redeploy sites so live widgets hit the public API.
PUBLIC_API_BASE_URL="http://localhost:8787"

# ---- Site Gate (v2 single-password dashboard lock) -------------------------
# REQUIRED on Railway. Any 64-char random string. If missing, the site
# locks itself (fail-closed) — a misconfigured deploy is better than an
# open door.
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SITE_GATE_JWT_SECRET=""
# Optional override for the baked-in password hash. Default password is
# $Khan1234455. To rotate it: bcrypt a new password and paste the hash here.
#   node -e "console.log(require('bcryptjs').hashSync('your-new-password', 12))"
SITE_GATE_PASSWORD_HASH=""
